      "parameters": {
        "jsCode": "const parseJsonString = (value) => {\n  const cleaned = value\n    .trim()\n    .replace(/^```json\\s*/i, '')\n    .replace(/^```\\s*/i, '')\n    .replace(/\\s*```$/i, '')\n    .trim();\n\n  return JSON.parse(cleaned);\n};\n\nlet raw = $json.output ?? $json.text ?? $json.response ?? $json;\n\nif (typeof raw === 'string') {\n  raw = parseJsonString(raw);\n}\n\nif (raw && typeof raw === 'object' && raw.output && typeof raw.output === 'object') {\n  raw = raw.output;\n}\n\nif (typeof raw === 'string') {\n  raw = parseJsonString(raw);\n}\n\nif (raw && typeof raw === 'object') {\n  return [{ json: raw }];\n}\n\nthrow new Error('Workflow tidak menghasilkan object JSON yang valid.');"
      },
